# ===============================
# Ayurkisan Backend Environment Template
# ===============================
# Instructions: Copy this file to '.env' and fill in your actual values.
# DO NOT commit the '.env' file to version control.

# Server Configuration
SERVER_PORT=9090

# MongoDB Configuration
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=your_mongodb_uri_here

# JWT Security
# Generate a long, secure, random string (at least 32 characters for HS256)
JWT_SECRET=PlaceholderSecretKeyAtLeast32CharsLong_2026
JWT_EXPIRATION=86400000

# Email Configuration (SMTP)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
